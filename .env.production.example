APP_NAME=ServerVault
APP_ENV=production
APP_KEY=CHANGE_ME_GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=your-db-host-or-rds-endpoint
DB_PORT=3306
DB_DATABASE=your_production_database
DB_USERNAME=your_db_user
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host-or-elasticache-endpoint
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
REDIS_PORT=6379

REVERB_APP_ID=CHANGE_ME_UNIQUE_ID
REVERB_APP_KEY=CHANGE_ME_UNIQUE_KEY
REVERB_APP_SECRET=CHANGE_ME_UNIQUE_SECRET
REVERB_HOST=your-domain.com
REVERB_PORT=443
REVERB_SCHEME=https

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=CHANGE_ME_IF_USING_S3
AWS_SECRET_ACCESS_KEY=CHANGE_ME_IF_USING_S3
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
