{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "docker:dev": "docker-compose up -d",
        "docker:dev:build": "docker-compose up -d --build",
        "docker:dev:down": "docker-compose down --remove-orphans",
        "docker:dev:logs": "docker-compose logs -f",
        "docker:dev:restart": "docker-compose restart",
        "docker:dev:shell": "docker-compose exec app bash",
        "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
        "docker:prod:build": "docker-compose -f docker-compose.prod.yml up -d --build",
        "docker:prod:down": "docker-compose -f docker-compose.prod.yml down --remove-orphans",
        "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
        "docker:prod:shell": "docker-compose -f docker-compose.prod.yml exec app bash",
        "docker:ps": "docker-compose ps",
        "docker:clean": "docker-compose down -v --remove-orphans && docker system prune -f",
        "artisan:migrate": "docker-compose exec app php artisan migrate",
        "artisan:migrate:fresh": "docker-compose exec app php artisan migrate:fresh",
        "artisan:seed": "docker-compose exec app php artisan db:seed",
        "artisan:key": "docker-compose exec app php artisan key:generate",
        "artisan:cache:clear": "docker-compose exec app php artisan optimize:clear",
        "artisan:prod:migrate": "docker-compose -f docker-compose.prod.yml exec app php artisan migrate --force",
        "artisan:prod:optimize": "docker-compose -f docker-compose.prod.yml exec app php artisan config:cache && docker-compose -f docker-compose.prod.yml exec app php artisan route:cache && docker-compose -f docker-compose.prod.yml exec app php artisan view:cache",
        "composer:install": "docker-compose exec app composer install",
        "composer:update": "docker-compose exec app composer update",
        "db:mysql": "docker-compose exec db mysql -u servervault -pservervault_password server_vault",
        "redis:cli": "docker-compose exec redis redis-cli"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.16.1",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@lucide/vue": "^1.23.0",
        "@tanstack/vue-table": "^8.21.3",
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^1.0.0",
        "motion-v": "^2.2.1",
        "pinia": "^3.0.4",
        "reka-ui": "^2.10.1",
        "shadcn-vue": "^2.7.3",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "vue-router": "^4.6.4",
        "vue-sonner": "^2.0.9",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0"
    }
}
